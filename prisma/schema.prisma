datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Fund {
  id                String      @id @default(cuid())
  name              String
  url               String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  lastScrapeAt      DateTime?
  lastScrapeStatus  String?
  lastScrapeMessage String?
  articles          Article[]
  scrapeLogs        ScrapeLog[]
}

model Article {
  id        String    @id @default(cuid())
  fundId    String
  fund      Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  headline  String
  url       String
  date      DateTime?
  summary   String?
  createdAt DateTime  @default(now())

  @@unique([fundId, url])
}

model ScrapeLog {
  id             String   @id @default(cuid())
  fundId         String
  fund           Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  timestamp      DateTime @default(now())
  itemsExtracted Int
  status         String
  errorMessage   String?
}
